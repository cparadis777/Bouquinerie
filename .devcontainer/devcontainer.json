{
  "name": "Bouquinerie",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspace",
  "remoteUser": "root",
  "containerUser": "root",
  "features": {},

  "postCreateCommand": "cargo install sea-orm-cli && cargo install cargo-watch",
  "forwardPorts": [3000, 5432, 8080],
  "portsAttributes": {
    "3000": { "label": "Rust API", "protocol": "http" },
    "5432": { "label": "PostgreSQL" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "task.vscode-task"
      ]
    }
  },
  
  "mounts": [
    "source=~/.ssh/,target=/root/.ssh,type=bind,consistency=cached",
    "source=${env:SSH_AUTH_SOCK},target=/tmp/ssh-agent.sock,type=bind"
  ],

  "containerEnv": {
    "SSH_AUTH_SOCK": "/tmp/ssh-agent.sock"
  }
}
