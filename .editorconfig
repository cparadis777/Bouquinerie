root = true

[*]
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.{rs,go}]
indent_style = space
indent_size = 4

[*.{ts,js,vue,json,jsonc,yaml,yml,toml,html,css}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
